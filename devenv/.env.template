# CineTagIt Production Environment Variables
# Copy this file to .env and fill in your own values

# Security keys (use strong random values in production)
JWT_SECRET_KEY=your_jwt_secret_key_here
SECRET_KEY=your_secret_key_here

# Database credentials
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_PASSWORD=your_mysql_password_here

# Redis credentials
REDIS_PASSWORD=your_redis_password_here

# Mail server credentials
MAIL_PASSWORD=your_mail_password_here

# API tokens
TMDB_API_TOKEN=your_tmdb_api_token_here

# Optional: Override other config values if needed
# SERVER_NAME=your_server_name_here
# MAIL_SERVER=your_mail_server_here
# MAIL_PORT=587
# MAIL_USERNAME=your_mail_username_here
# MAIL_DEFAULT_SENDER=your_mail_sender_here