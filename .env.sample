# CineTagIt Environment Variables Configuration
# Copy this file to .env and fill in the values

# Flask Environment (development, production, testing)
FLASK_ENV=development

# Application Secret Key (required for sessions and CSRF)
SECRET_KEY=your-secret-key-change-it-in-production

# Database URI (defaults to SQLite in the project root)
# DATABASE_URI=sqlite:///app.db
# DATABASE_URI=postgresql://user:password@localhost/dbname

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-it-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# Mail Configuration (MailHog defaults for local development)
MAIL_SERVER=mailhog
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@cinetag.it

# TMDB Configuration
# Get your API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key

# Region and Language Settings
DEFAULT_REGION=US
DEFAULT_LANGUAGE=en

# Cache Configuration
# CACHE_TYPE=flask_caching.backends.simplecache.SimpleCache

# Gunicorn workers and threads. Defaults: 2 workers, 8 threads (gthread class).
# Threads give concurrency for I/O-bound endpoints (poster fetch, TMDB).
# Multiple workers are safe: only one worker per container acquires the
# scheduler.lock and runs cron jobs, and the email + notification queue
# drains use SELECT FOR UPDATE SKIP LOCKED so concurrent callers (scheduler,
# future manual trigger, etc.) never claim the same row twice.
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=8
